#============================================================
# 星河百谷 - 生产环境变量配置
# 使用方式: cp .env.example .env && vim .env
#============================================================

#------------------------------------------------------------
# 基础配置
#------------------------------------------------------------
NODE_ENV=production
PORT=3000

#------------------------------------------------------------
# 域名配置 (用于小程序和H5)
#------------------------------------------------------------
PROJECT_DOMAIN=https://your-domain.com

#------------------------------------------------------------
# MySQL 数据库配置 (微信云托管)
# 从微信云托管控制台获取数据库连接信息
#------------------------------------------------------------
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=xh_club

#------------------------------------------------------------
# 微信云托管对象存储（腾讯 COS）
# Bucket 和 Region 可从微信云托管对象存储控制台获取
# 私有桶场景由后端生成预签名 URL（默认 7200 秒）
#------------------------------------------------------------
COS_BUCKET=your-bucket-1250000000
COS_REGION=ap-shanghai
COS_SIGNED_URL_EXPIRES=7200
# 可选：本地调试时使用永久密钥；云托管内优先走 getauth 临时密钥
# COS_SECRET_ID=
# COS_SECRET_KEY=

#------------------------------------------------------------
# 微信小程序登录
#------------------------------------------------------------
WX_APP_ID=your-wechat-mini-program-appid
WX_APP_SECRET=your-wechat-mini-program-app-secret
TARO_APP_WEAPP_APPID=your-wechat-mini-program-appid

#------------------------------------------------------------
# 微信云托管 callContainer（小程序免配服务器域名）
#------------------------------------------------------------
TARO_APP_WX_CLOUD_ENV=your-cloud-env-id
TARO_APP_WX_CLOUD_SERVICE=xh-server

#------------------------------------------------------------
# JWT 密钥 (用于管理员登录等)
# 建议: 使用 openssl rand -hex 32 生成
#------------------------------------------------------------
JWT_SECRET=your-jwt-secret-key-change-this

#------------------------------------------------------------
# 首次数据库迁移时创建管理员所用密码
# 管理员创建完成后可移除此变量
#------------------------------------------------------------
ADMIN_INITIAL_PASSWORD=your-one-time-strong-admin-password

#------------------------------------------------------------
# 日志配置
#------------------------------------------------------------
LOG_LEVEL=info
