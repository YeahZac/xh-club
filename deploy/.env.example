# ============================================================
# 星河百谷商会平台 - 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---------- 必须配置 ----------
# 从 Coze 沙箱环境变量中获取
COZE_SUPABASE_URL=https://xxxxx.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 项目域名（小程序 request 合法域名需要配置）
PROJECT_DOMAIN=https://your-domain.com

# JWT 密钥（随机生成一个长字符串）
JWT_SECRET=your-random-jwt-secret-change-this

# ---------- 可选配置 ----------
# 服务端口
PORT=3000

# Node 环境
NODE_ENV=production
